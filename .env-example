# ============================================
# .env-example — VibeCheck
# ============================================
# Copie este arquivo para .env e preencha os valores.
# Uso: cp .env-example .env
# ============================================

# ------------------------------------------
# PostgreSQL
# ------------------------------------------
POSTGRES_DB=vibecheck
POSTGRES_USER=vibecheck_user
POSTGRES_PASSWORD=COLOQUE_UMA_SENHA_SEGURA_AQUI

# ------------------------------------------
# Backend (.NET 8 API)
# ------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
DATABASE_PROVIDER=Postgres

# Autenticação Google OAuth2
GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=SEU_GOOGLE_CLIENT_SECRET

# ------------------------------------------
# Frontend (Vite + React)
# ------------------------------------------
VITE_API_BASE_URL=http://localhost:8080
VITE_API_TIMEOUT=10000

# ------------------------------------------
# Docker Compose Produção
# ------------------------------------------
# Owner da organização/usuário no GitHub (usado para puxar imagens GHCR)
GITHUB_REPOSITORY_OWNER=ValeriaCristinaGL

# Tag da imagem Docker (ex: 1.0.0, latest)
TAG=latest
